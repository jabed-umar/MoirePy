# Rust build artifacts (can be large — regenerated by cargo/wasm-pack)
/target/

# wasm-pack also writes a .gitignore inside pkg/ that ignores everything.
# Override it so the compiled WASM and JS glue ARE committed to the repo
# (MkDocs serves them as static assets; no Rust toolchain needed at deploy time).
!/pkg/
!/pkg/*.js
!/pkg/*.wasm
!/pkg/*.d.ts
